# Exemplo de variáveis de ambiente. Copie para `.env.local` e preencha.
# `.env.local` é ignorado pelo git (segredos não entram no repo).

# Token por-app que o MC usa no push mc→app (Authorization: Bearer <token>).
# É o mesmo `mcat_…` emitido para este app no MC. Sem ele, POST /mc/callback responde 503.
MC_APP_TOKEN=
